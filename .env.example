# Spotify OAuth
# Create an app at https://developer.spotify.com/dashboard
# Add http://localhost:5173/api/auth/callback to Redirect URIs (local dev)
# Add https://your-app.vercel.app/api/auth/callback (production)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:5173/api/auth/callback

# Anthropic API
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# No key needed for TheCocktailDB — it's called directly from server routes
